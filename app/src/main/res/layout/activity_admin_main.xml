<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="vertical">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:elevation="2dp">

            <!-- ═══ HEADER MODERNO LIMPIO ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                app:layout_scrollFlags="scroll|enterAlways|snap">

                <!-- IZQUIERDA: Título + Subtítulo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAdminSeccion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01" />

                    <TextView
                        android:id="@+id/tvAdminNombreMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:alpha="0.65"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Notificaciones con badge -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="6dp">

                    <ImageButton
                        android:id="@+id/btnHeaderNotificaciones"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_ripple_circle"
                        android:contentDescription="Notificaciones"
                        android:padding="8dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="#5F6368" />

                    <View
                        android:id="@+id/viewNotificationDot"
                        android:layout_width="9dp"
                        android:layout_height="9dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="7dp"
                        android:layout_marginEnd="7dp"
                        android:background="@drawable/bg_notification_dot" />
                </FrameLayout>

                <!-- Búsqueda -->
                <ImageButton
                    android:id="@+id/btnHeaderBusqueda"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_icon_ripple_circle"
                    android:contentDescription="Buscar"
                    android:padding="8dp"
                    android:src="@drawable/ic_search"
                    app:tint="#5F6368" />

                <!-- Avatar usuario -->
                <FrameLayout
                    android:id="@+id/btnHeaderAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_avatar_admin"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/bg_icon_ripple_circle"
                    android:contentDescription="Perfil">

                    <TextView
                        android:id="@+id/tvHeaderAvatarInicial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#5F6368"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </FrameLayout>

            </LinearLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <!-- CONTENEDOR DE FRAGMENTOS -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/adminFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/adminBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        app:itemIconTint="@color/selector_nav_admin"
        app:itemTextColor="@color/selector_nav_admin"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/admin_bottom_nav" />

</LinearLayout>

