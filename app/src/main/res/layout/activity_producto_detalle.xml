<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="vertical">

    <!-- ── CONTENIDO SCROLLEABLE ────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── IMAGEN CON BOTONES SUPERPUESTOS ──────────────────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@color/green_light">

                <!-- Imagen placeholder del producto -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/ivDetalleImagen"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_cart"
                        android:scaleType="centerCrop"
                        android:alpha="0.35" />
                </LinearLayout>

                <!-- Botón volver (arriba-izquierda) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnVolverDetalle"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="21dp"
                    app:cardElevation="4dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/text_primary" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Botones favorito + compartir (arriba-derecha) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:orientation="horizontal">

                    <!-- Favorito -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnFavoritoDetalle"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="21dp"
                        app:cardElevation="4dp">
                        <ImageView
                            android:id="@+id/ivFavoritoDetalle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@drawable/ic_favorite"
                            app:tint="@color/text_secondary" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Compartir -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnCompartirDetalle"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="21dp"
                        app:cardElevation="4dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@drawable/ic_logout"
                            app:tint="@color/text_secondary" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

            </FrameLayout>

            <!-- ── TARJETA BLANCA (superpuesta, esquinas redondeadas arriba) ─ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-28dp"
                android:background="@drawable/bg_white_rounded_top"
                android:elevation="6dp"
                android:orientation="vertical"
                android:paddingHorizontal="22dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- ── NOMBRE + BADGE ────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDetalleNombre"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.1" />


                </LinearLayout>

                <!-- ── CATEGORÍA · MARCA ─────────────────────────────────── -->
                <TextView
                    android:id="@+id/tvDetalleCategoria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <!-- ── RATING ROW ────────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <RatingBar
                        android:id="@+id/ratingBarDetalle"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:isIndicator="false"
                        android:numStars="5"
                        android:progressTint="@color/star_yellow"
                        android:rating="0"
                        android:stepSize="0.5" />

                    <TextView
                        android:id="@+id/tvSinResenas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Sin reseñas aún"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ── FORMULARIO RESEÑA ──────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/resenaFormSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Escribe tu reseña (opcional)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/green_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etResena"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:maxLines="4"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnEnviarResena"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="end"
                        android:backgroundTint="@color/green_primary"
                        android:text="Enviar reseña"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <!-- ── DIVISOR ────────────────────────────────────────────── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:background="@color/card_stroke" />

                <!-- ── DESCRIPCIÓN ────────────────────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Descripción"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetalleDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <!-- ── VARIANTES ──────────────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/variantesSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/card_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Opciones"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupVariantes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:singleSelection="true" />
                </LinearLayout>

                <!-- ── PRECIO ─────────────────────────────────────────────── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:background="@color/card_stroke" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">


                        <!-- Precio actual -->
                        <TextView
                            android:id="@+id/tvDetallePrecio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Stock badge -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/green_light"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:id="@+id/tvDetalleStock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:textColor="@color/green_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── BARRA INFERIOR FIJA: CANTIDAD + AGREGAR AL CARRITO ─────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp">

        <!-- Selector de cantidad -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            app:cardBackgroundColor="@color/bg_screen"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <ImageButton
                    android:id="@+id/btnRestarCantidad"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_qty_btn"
                    android:src="@drawable/ic_remove"
                    android:padding="8dp"
                    app:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tvCantidadDetalle"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnSumarCantidad"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_green"
                    android:src="@android:drawable/ic_input_add"
                    android:padding="8dp"
                    app:tint="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnAgregarCarritoDetalle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:backgroundTint="@color/green_primary"
            android:letterSpacing="0.05"
            android:text="Agregar al Carrito"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />
    </LinearLayout>

</LinearLayout>


