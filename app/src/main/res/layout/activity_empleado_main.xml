<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="vertical">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:elevation="2dp">

            <!-- ═══ HEADER MODERNO LIMPIO ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                app:layout_scrollFlags="scroll|enterAlways|snap">

                <!-- IZQUIERDA: Título + Subtítulo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEmpleadoSeccion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01" />

                    <TextView
                        android:id="@+id/tvEmpleadoNombreMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:alpha="0.65"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Badge solo lectura -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_chip_categoria"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Solo lectura"
                    android:textColor="@color/green_dark"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <!-- Avatar usuario -->
                <FrameLayout
                    android:id="@+id/btnHeaderAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_avatar_admin"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/bg_icon_ripple_circle"
                    android:contentDescription="Perfil">

                    <TextView
                        android:id="@+id/tvHeaderAvatarInicial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#5F6368"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </FrameLayout>

            </LinearLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <!-- CONTENEDOR DE FRAGMENTOS -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/empleadoFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/empleadoBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        app:itemIconTint="@color/selector_nav_admin"
        app:itemTextColor="@color/selector_nav_admin"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/empleado_bottom_nav" />

</LinearLayout>

