<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <!-- Imagen del producto -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="68dp"
            android:layout_height="68dp"
            app:cardBackgroundColor="@color/bg_screen"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/ivAdminProducto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Producto"
                android:padding="8dp"
                android:scaleType="fitCenter" />

            <View
                android:id="@+id/viewAdminSkeleton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F0F0F0" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Info del producto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAdminNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.005" />

            <!-- Badges categoría + marca -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAdminCategoria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_categoria"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/green_dark"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminMarca"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Precio + Stock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAdminPrecio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/green_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@color/text_secondary"
                    android:alpha="0.4" />

                <TextView
                    android:id="@+id/tvAdminStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botones: editar + eliminar (solo admin) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Editar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardBackgroundColor="@color/green_light"
                app:cardCornerRadius="11dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageButton
                    android:id="@+id/btnEditarProducto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:contentDescription="Editar"
                    android:padding="8dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/green_dark" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Eliminar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/danger_bg"
                app:cardCornerRadius="11dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageButton
                    android:id="@+id/btnEliminarProducto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:contentDescription="Eliminar"
                    android:padding="8dp"
                    android:src="@drawable/ic_delete"
                    app:tint="@color/danger_red" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
