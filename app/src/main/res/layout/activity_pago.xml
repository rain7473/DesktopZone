<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:elevation="4dp"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnVolverPago"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@color/bg_screen"
                android:src="@drawable/ic_back"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Pago Seguro"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View android:layout_width="40dp" android:layout_height="40dp" />
        </LinearLayout>

        <!-- TOTAL CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/green_primary"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total a pagar"
                    android:textColor="#CCffffff"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvTotalPagar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="🔒  Pago 100% seguro"
                    android:textColor="#CCffffff"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SELECTOR MÉTODO DE PAGO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Título -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💳  "
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Método de pago"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Fila 1: Visa Crédito | Visa Débito -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <!-- Visa Crédito -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVisaCredito"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#1A237E"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VISA"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-condensed"
                                android:letterSpacing="0.15" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Crédito"
                                android:textColor="#B0BEC5"
                                android:textSize="11sp"
                                android:layout_marginTop="3dp" />
                        </LinearLayout>

                        <!-- Indicador seleccionado -->
                        <ImageView
                            android:id="@+id/ivCheckVisaCredito"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="6dp"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="#FFFFFF" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Visa Débito -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVisaDebito"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#1565C0"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VISA"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-condensed"
                                android:letterSpacing="0.15" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Débito"
                                android:textColor="#B0BEC5"
                                android:textSize="11sp"
                                android:layout_marginTop="3dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivCheckVisaDebito"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="6dp"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="#FFFFFF" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Fila 2: Mastercard Crédito | Mastercard Débito -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Mastercard Crédito -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMcCredito"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#B71C1C"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">

                            <!-- Círculos Mastercard -->
                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="22dp">

                                <View
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:background="@drawable/circle_mc_red"
                                    android:layout_gravity="start" />

                                <View
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:background="@drawable/circle_mc_orange"
                                    android:layout_gravity="end"
                                    android:layout_marginStart="12dp" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Crédito"
                                android:textColor="#B0BEC5"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivCheckMcCredito"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="6dp"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="#FFFFFF" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mastercard Débito -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMcDebito"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#880E4F"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="10dp">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="22dp">

                                <View
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:background="@drawable/circle_mc_red"
                                    android:layout_gravity="start" />

                                <View
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:background="@drawable/circle_mc_orange"
                                    android:layout_gravity="end"
                                    android:layout_marginStart="12dp" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Débito"
                                android:textColor="#B0BEC5"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivCheckMcDebito"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="6dp"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="#FFFFFF" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Texto método seleccionado -->
                <TextView
                    android:id="@+id/tvMetodoSeleccionado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Selecciona un método de pago"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD FORM -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💳  "
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Datos de tarjeta"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Nombre (oculto - no requerido) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNombre"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Nombre en la tarjeta"
                    app:errorEnabled="true"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNombreTarjeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionNext"
                        android:inputType="textPersonName|textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Número de tarjeta -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDigitos"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Número de tarjeta (16 dígitos)"
                    app:errorEnabled="true"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDigitos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionNext"
                        android:inputType="number"
                        android:maxLength="16" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Fecha y CVV en fila -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFecha"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:hint="MM/AA"
                        app:errorEnabled="true"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFechaVence"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionNext"
                            android:inputType="number"
                            android:maxLength="5" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCvv"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="CVV"
                        app:errorEnabled="true"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCvv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionDone"
                            android:inputType="numberPassword"
                            android:maxLength="4" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- ProgressBar -->
                <ProgressBar
                    android:id="@+id/progressPago"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:indeterminateTint="@color/green_primary"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnConfirmarPago"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/green_primary"
                    android:text="Confirmar Pago"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
